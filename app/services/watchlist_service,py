from sqlalchemy.orm import Session
from fastapi import HTTPException, status
from app.models.interaction import Watchlist
import uuid

def add_to_watchlist(db: Session, user_id: uuid.UUID, movie_id: int):
    existing = db.query(Watchlist).filter_by(user_id=user_id, movie_id=movie_id).first()
    if existing:
        raise HTTPException(status_code=status.HTTP_409_CONFLICT, detail="Already in watchlist")
    entry = Watchlist(user_id=user_id, movie_id=movie_id)
    db.add(entry)
    db.commit()

def remove_from_watchlist(db: Session, user_id: uuid.UUID, movie_id: int):
    entry = db.query(Watchlist).filter_by(user_id=user_id, movie_id=movie_id).first()
    if not entry:
        raise HTTPException(status_code=status.HTTP_404_NOT_FOUND, detail="Not in watchlist")
    db.delete(entry)
    db.commit()

def get_watchlist(db: Session, user_id: uuid.UUID) -> list[Watchlist]:
    return db.query(Watchlist).filter(Watchlist.user_id == user_id).all()

def is_in_watchlist(db: Session, user_id: uuid.UUID, movie_id: int) -> bool:
    return db.query(Watchlist).filter_by(user_id=user_id, movie_id=movie_id).first() is not None